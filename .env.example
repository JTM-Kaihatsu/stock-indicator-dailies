# Stock Indicator Dailies — environment template
# Copy to .env.local and fill in. NEVER commit the filled-in file.

# --- AI layer: frontier VLM (Claude / Gemini / GPT-class) ---
# Provider is pluggable; set the one you're using and its key.
VLM_PROVIDER=claude
VLM_MODEL=claude-sonnet-5
# For Claude: create a key at https://console.anthropic.com → API keys.
VLM_API_KEY=

# --- Database: Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Agentic layer: charting provider ---
# Preferred: OAuth / scoped read-only API keys over raw passwords.
# For local dev only — production credentials belong in an OS-level vault (Keychain),
# not in this file. See docs/ARCHITECTURE.md#security--risk.
CHART_PROVIDER=tradingview
CHART_PROVIDER_USERNAME=
CHART_PROVIDER_PASSWORD=

# --- Agent behavior ---
# Human-like interaction timing + rate limiting to avoid bot mitigation / account suspension.
AGENT_HEADLESS=true
AGENT_MIN_ACTION_DELAY_MS=400
AGENT_MAX_ACTION_DELAY_MS=1200
