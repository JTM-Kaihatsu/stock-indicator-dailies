{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    // page.evaluate() callbacks execute in the browser, so DOM globals are in
    // scope inside them. Only this package needs DOM types.
    "lib": ["ES2023", "DOM"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
